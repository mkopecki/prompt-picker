{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prompt Picker",
  "version": "0.1.0",
  "identifier": "com.prompt-picker.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI3ODBCODE1NTU4OEE5RDgKUldUWXFZaFZGYmlBSjU0bmk2eWYzZ2NSajRYRVIyTE9EUURHQzREVFhlbmtyNDZDaXkyK3BnTHMK",
      "endpoints": [
        "https://github.com/mkopecki/prompt-picker/releases/latest/download/latest.json"
      ]
    }
  }
}
